# Copy this file to start.local.env and fill in local-only values.
# start.local.env is ignored by git through the repo-wide *.env rule.

MessagingBroker__EnvironmentName=dev-local
MessagingBroker__SourceSystem=transportados
TRANSPORTADOS_DEV_ANDROID_TARGET=Physical
TRANSPORTADOS_DEV_ANDROID_WIFI_DEVICE=192.168.1.50:5555
EmailBroker__BaseUrl=https://transportados-wa-webhook.transportados.com/
EmailBroker__InternalApiSharedSecret=replace-with-broker-internal-api-secret
EmailBroker__Transport__SenderName=Transportados
EmailBroker__Transport__EmailFrom=replace-with-from-email
EmailBroker__Transport__Host=replace-with-smtp-host
EmailBroker__Transport__Port=2525
EmailBroker__Transport__User=replace-with-smtp-user
EmailBroker__Transport__Pass=replace-with-smtp-password
EmailBroker__Transport__UseSsl=false
EmailBroker__Transport__CcEmails=
