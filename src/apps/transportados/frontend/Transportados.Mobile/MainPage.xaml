<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Transportados.Client.Components;assembly=Transportados.Client"
             x:Class="Transportados.Mobile.MainPage"
             SafeAreaEdges="Container">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type components:TransportadosClientApp}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
