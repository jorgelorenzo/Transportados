@page "/platform/tenants"
@attribute [Authorize(Roles = TransportadosAccessMatrix.PlatformRolesCsv)]
@inject ITransportadosApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Organizaciones - Transportados</PageTitle>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption">Tenants</MudText>
            <MudText Typo="Typo.h5">@_stats.TotalTenants</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption">Pendientes</MudText>
            <MudText Typo="Typo.h5">@_stats.PendingTenants</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption">Usuarios</MudText>
            <MudText Typo="Typo.h5">@_stats.TotalUsers</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.caption">Clientes</MudText>
            <MudText Typo="Typo.h5">@_stats.TotalCustomers</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<ServerPagedTable TItem="TenantListItemDto" @ref="_tenantsTable" ServerData="LoadTenantsPageAsync">
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Estado</MudTh>
        <MudTh>Contacto</MudTh>
        <MudTh Class="text-end">Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">@context.Name</MudTd>
        <MudTd DataLabel="Estado">
            <MudChip T="string" Size="Size.Small" Color="@TenantStatusColor(context.Status)" Variant="Variant.Outlined">
                @TransportadosDisplayLabels.TenantStatus(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Contacto">
            @if (string.IsNullOrWhiteSpace(context.RegistrationContactEmail))
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sin email</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2">@context.RegistrationContactEmail</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Acciones" Class="text-end">
            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                <MudTooltip Text="Funcionalidades">
                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="@_isBusy"
                                   OnClick="@(() => SelectFeaturesAsync(context))"
                                   aria-label="@($"Editar funcionalidades de {context.Name}")" />
                </MudTooltip>
                @if (context.Status == TenantStatus.Pending || context.Status == TenantStatus.Disabled)
                {
                    <MudTooltip Text="Activar">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                       Color="Color.Success"
                                       Size="Size.Small"
                                       Disabled="@_isBusy"
                                       OnClick="@(() => ChangeTenantStatusAsync(context, TenantStatus.Active))"
                                       aria-label="@($"Activar {context.Name}")" />
                    </MudTooltip>
                }
                else
                {
                    <MudTooltip Text="Desactivar">
                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       Disabled="@_isBusy"
                                       OnClick="@(() => ChangeTenantStatusAsync(context, TenantStatus.Disabled))"
                                       aria-label="@($"Desactivar {context.Name}")" />
                    </MudTooltip>
                }
            </MudStack>
        </MudTd>
    </RowTemplate>
</ServerPagedTable>

@if (_selectedTenant != null)
{
    <MudPaper Class="pa-4 mt-4" Elevation="1">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">@_selectedTenant.Name</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearSelection" aria-label="Cerrar" />
        </MudStack>

        @if (_featureForm != null)
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" md="3">
                    <MudSwitch T="bool" @bind-Value="_featureForm.Appearance" Color="Color.Primary" Label="Apariencia" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSwitch T="bool" @bind-Value="_featureForm.Email" Color="Color.Primary" Label="Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@_isBusy"
                               OnClick="SaveFeaturesAsync">
                        Guardar funcionalidades
                    </MudButton>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>
}

@code {
    private ServerPagedTable<TenantListItemDto>? _tenantsTable;
    private PlatformStatsDto _stats = new();
    private TenantListItemDto? _selectedTenant;
    private TenantFeatureFlagsDto? _featureForm;
    private bool _isBusy;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            _stats = await Api.GetAsync<PlatformStatsDto>("api/platform/stats") ?? new PlatformStatsDto();
            if (_tenantsTable != null)
            {
                await _tenantsTable.ReloadServerDataAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task<TableData<TenantListItemDto>> LoadTenantsPageAsync(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var page = state.Page + 1;
            var pageSize = state.PageSize <= 0 ? 20 : state.PageSize;
            var items = await Api.GetAsync<List<TenantListItemDto>>($"api/platform/tenants?page={page}&pageSize={pageSize}") ?? [];
            return new TableData<TenantListItemDto>
            {
                Items = items,
                TotalItems = items.Count < pageSize ? state.Page * pageSize + items.Count : (state.Page + 2) * pageSize
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            return new TableData<TenantListItemDto> { Items = [], TotalItems = 0 };
        }
    }

    private async Task SelectFeaturesAsync(TenantListItemDto tenant)
    {
        _selectedTenant = tenant;
        var detail = await Api.GetAsync<TenantDetailDto>($"api/platform/tenants/{tenant.Id:D}");
        _featureForm = detail?.Features ?? new TenantFeatureFlagsDto();
    }

    private async Task SaveFeaturesAsync()
    {
        if (_selectedTenant == null || _featureForm == null)
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Api.PostAsync<TenantUpdateRequestDto, object>(
                $"api/platform/tenants/{_selectedTenant.Id:D}",
                new TenantUpdateRequestDto { Features = _featureForm });
            Snackbar.Add("Funcionalidades guardadas.", Severity.Success);
            ClearSelection();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ChangeTenantStatusAsync(TenantListItemDto tenant, TenantStatus status)
    {
        _isBusy = true;
        try
        {
            await Api.PostAsync<TenantUpdateRequestDto, object>(
                $"api/platform/tenants/{tenant.Id:D}",
                new TenantUpdateRequestDto { Status = status });
            Snackbar.Add("Estado actualizado.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ClearSelection()
    {
        _selectedTenant = null;
        _featureForm = null;
    }

    private static Color TenantStatusColor(TenantStatus status) =>
        status switch
        {
            TenantStatus.Active => Color.Success,
            TenantStatus.Pending => Color.Warning,
            TenantStatus.Disabled => Color.Error,
            _ => Color.Default
        };
}
