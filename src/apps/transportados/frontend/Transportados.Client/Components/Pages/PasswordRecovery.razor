@page "/password-recovery"
@page "/first-login"
@layout LoginLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using System.ComponentModel.DataAnnotations

<PageTitle>@PageTitleText - Transportados</PageTitle>

<MudPaper Class="pa-6" Elevation="2" Style="max-width: 460px; width: 100%;">
    <div class="d-flex align-center mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Color="Color.Secondary"
                       OnClick="GoToLogin"
                       aria-label="Volver al login"
                       title="Volver al login" />
        <MudText Typo="Typo.h6" Class="ms-2">@HeadingText</MudText>
    </div>

    <div class="transportados-login-brand">
        <img src="/android-chrome-192x192.png" alt="Transportados" class="transportados-login-brand-icon" />
        <MudText Typo="Typo.h5" Class="transportados-login-brand-title">Transportados</MudText>
    </div>

    @if (_step == 1)
    {
        <EditForm Model="_codeRequest" OnValidSubmit="SendVerificationCode" FormName="otPasswordRecoveryCodeForm">
            <DataAnnotationsValidator />

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">
                Ingrese su email y le enviaremos un codigo de verificacion.
            </MudText>

            <MudTextField @bind-Value="_codeRequest.Email"
                          For="() => _codeRequest.Email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Immediate="true"
                          Required="true"
                          RequiredError="El email es requerido"
                          Class="mb-4" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="_isLoading"
                       StartIcon="@(_isLoading ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.MarkEmailRead)"
                       Class="mb-2">
                @(_isLoading ? "Enviando" : "Enviar codigo")
            </MudButton>
        </EditForm>
    }
    else
    {
        <EditForm Model="_passwordRequest" OnValidSubmit="ChangePassword" FormName="otPasswordRecoveryChangeForm">
            <DataAnnotationsValidator />

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">
                Ingrese el codigo recibido y su nueva clave.
            </MudText>

            <MudTextField @bind-Value="_passwordRequest.Email"
                          For="() => _passwordRequest.Email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Immediate="true"
                          Required="true"
                          RequiredError="El email es requerido"
                          Class="mb-3" />

            <MudTextField @bind-Value="_passwordRequest.VerificationCode"
                          For="() => _passwordRequest.VerificationCode"
                          Label="Codigo"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Required="true"
                          RequiredError="El codigo es requerido"
                          Class="mb-3" />

            <MudTextField @bind-Value="_passwordRequest.NewPassword"
                          For="() => _passwordRequest.NewPassword"
                          Label="Nueva clave"
                          Variant="Variant.Outlined"
                          InputType="@NewPasswordInputType"
                          Immediate="true"
                          Required="true"
                          RequiredError="La nueva clave es requerida"
                          Adornment="Adornment.End"
                          AdornmentIcon="@NewPasswordIcon"
                          OnAdornmentClick="ToggleNewPasswordVisibility"
                          Class="mb-3" />

            <MudTextField @bind-Value="_passwordRequest.ConfirmPassword"
                          For="() => _passwordRequest.ConfirmPassword"
                          Label="Confirmar clave"
                          Variant="Variant.Outlined"
                          InputType="@ConfirmPasswordInputType"
                          Immediate="true"
                          Required="true"
                          RequiredError="La confirmacion es requerida"
                          Adornment="Adornment.End"
                          AdornmentIcon="@ConfirmPasswordIcon"
                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                          Class="mb-4" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="_isLoading"
                       StartIcon="@(_isLoading ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.LockReset)"
                       Class="mb-2">
                @(_isLoading ? "Cambiando" : "Cambiar clave")
            </MudButton>

            <MudButton Variant="Variant.Text"
                       Color="Color.Secondary"
                       FullWidth="true"
                       OnClick="BackToEmailStep"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                Volver
            </MudButton>
        </EditForm>
    }
</MudPaper>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? EmailParam { get; set; }

    [SupplyParameterFromQuery(Name = "code")]
    public string? CodeParam { get; set; }

    [SupplyParameterFromQuery(Name = "step")]
    public int? StepParam { get; set; }

    private readonly PasswordRecoveryCodeModel _codeRequest = new();
    private readonly PasswordChangeModel _passwordRequest = new();
    private int _step = 1;
    private bool _isLoading;
    private bool _showNewPassword;
    private bool _showConfirmPassword;

    private bool IsFirstLoginMode =>
        Navigation.Uri.Contains("/first-login", StringComparison.OrdinalIgnoreCase);

    private string PageTitleText => IsFirstLoginMode ? "Primer ingreso" : "Recuperar clave";
    private string HeadingText => _step == 1 ? "Recuperar clave" : "Cambiar clave";
    private InputType NewPasswordInputType => _showNewPassword ? InputType.Text : InputType.Password;
    private InputType ConfirmPasswordInputType => _showConfirmPassword ? InputType.Text : InputType.Password;
    private string NewPasswordIcon => _showNewPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string ConfirmPasswordIcon => _showConfirmPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(EmailParam))
        {
            _codeRequest.Email = EmailParam;
            _passwordRequest.Email = EmailParam;
        }

        if (!string.IsNullOrWhiteSpace(CodeParam))
        {
            _passwordRequest.VerificationCode = CodeParam;
        }

        _step = StepParam is 1 or 2
            ? StepParam.Value
            : IsFirstLoginMode || !string.IsNullOrWhiteSpace(CodeParam) ? 2 : 1;
    }

    private async Task SendVerificationCode()
    {
        _isLoading = true;
        try
        {
            var (success, errorMessage) = await AuthService.RequestPasswordRecoveryCodeAsync(
                _codeRequest.Email,
                Navigation.BaseUri);

            if (!success)
            {
                Snackbar.Add(errorMessage ?? "No se pudo enviar el codigo.", Severity.Error);
                return;
            }

            _passwordRequest.Email = _codeRequest.Email;
            _step = 2;
            Snackbar.Add("Si el email corresponde a una cuenta, enviaremos un codigo de recuperacion.", Severity.Success);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ChangePassword()
    {
        if (_passwordRequest.NewPassword != _passwordRequest.ConfirmPassword)
        {
            Snackbar.Add("Las claves no coinciden.", Severity.Warning);
            return;
        }

        _isLoading = true;
        try
        {
            var (success, errorMessage) = await AuthService.ChangePasswordWithCodeAsync(
                _passwordRequest.Email,
                _passwordRequest.VerificationCode,
                _passwordRequest.NewPassword);

            if (!success)
            {
                Snackbar.Add(errorMessage ?? "No se pudo cambiar la clave.", Severity.Error);
                return;
            }

            Snackbar.Add("Clave actualizada. Ingrese con la nueva clave.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToEmailStep()
    {
        if (IsFirstLoginMode)
        {
            GoToLogin();
            return;
        }

        _step = 1;
    }

    private void GoToLogin() => Navigation.NavigateTo("/login");

    private void ToggleNewPasswordVisibility() => _showNewPassword = !_showNewPassword;

    private void ToggleConfirmPasswordVisibility() => _showConfirmPassword = !_showConfirmPassword;

    private sealed class PasswordRecoveryCodeModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;
    }

    private sealed class PasswordChangeModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string VerificationCode { get; set; } = string.Empty;

        [Required]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
