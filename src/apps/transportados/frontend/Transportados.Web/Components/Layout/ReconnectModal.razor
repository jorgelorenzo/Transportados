<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible">
            Reconectando con el servidor...
        </p>
        <p class="components-reconnect-repeated-attempt-visible">
            No se pudo reconectar. Reintentando en <span id="components-seconds-to-next-attempt"></span> segundos.
        </p>
        <p class="components-reconnect-failed-visible">
            No se pudo reconectar.<br />Reintenta o recarga la pagina.
        </p>
        <button id="components-reconnect-button"
                class="components-reconnect-failed-visible"
                aria-label="Reintentar"
                title="Reintentar">
            <svg class="components-reconnect-button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M17.65 6.35A7.95 7.95 0 0 0 12 4a8 8 0 1 0 7.45 5h-2.1A6 6 0 1 1 12 6c1.66 0 3.14.69 4.22 1.78L13 11h8V3z" />
            </svg>
        </button>
        <p class="components-pause-visible">
            La sesion fue pausada por el servidor.
        </p>
        <p class="components-resume-failed-visible">
            No se pudo reanudar la sesion.<br />Reintenta o recarga la pagina.
        </p>
        <button id="components-resume-button"
                class="components-pause-visible components-resume-failed-visible"
                aria-label="Reanudar"
                title="Reanudar">
            <svg class="components-reconnect-button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M8 5v14l11-7z" />
            </svg>
        </button>
    </div>
</dialog>
